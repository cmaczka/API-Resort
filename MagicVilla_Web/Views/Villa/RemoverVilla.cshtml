@model MagicVilla_Web.Models.VillaDto

@{
    ViewData["Title"] = "RemoverVilla";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Remover Villa</h1>
<form asp-action="RemoverVilla" method="post">

    <div class="container border p-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    </div>

    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="RowVersion" />
    <div class="row">
        <h2 class="text-info">Remover Villa</h2>
    </div>

    <div class="row mt-2">
        <div class="col-md-6">
            <label asp-for="Nombre" class="control-label"></label>
            <input asp-for="Nombre" disabled class="form-control" />
        </div>
    </div>


    <div class="row mt-2">
        <div class="col-md-6">
            <label asp-for="Tarifa" class="control-label"></label>
            <input asp-for="Tarifa" disabled class="form-control" />
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-md-6">
            <label asp-for="Detalle" class="control-label"></label>
            <textarea asp-for="Detalle" disabled class="form-control"></textarea>
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-md-6">
            <label asp-for="ImageUrl" class="control-label"></label>
            <input asp-for="ImageUrl" disabled class="form-control" />
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-md-6">
            <label asp-for="Ocupantes" class="control-label"></label>
            <input asp-for="Ocupantes" disabled class="form-control" />
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-md-6">
            <label asp-for="MetrosCuadrados" class="control-label"></label>
            <input asp-for="MetrosCuadrados" disabled class="form-control" />
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-md-6">
            <label asp-for="Amenidad" class="control-label"></label>
            <input asp-for="Amenidad" disabled class="form-control" />
        </div>
    </div>
    <div class="d-grid gap-2 d-md-block mt-2">
        <input type="submit" value="Remover" class="btn btn-danger" />
        <a asp-controller="Villa" asp-action="IndexVilla" class="btn btn-secondary">Back to List</a>
    </div>
</form>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

